{
  "name": "bff-mv-streaming-col",
  "version": "1.0.0",
  "description": "Live Games Real-Time BFF — Atlantic City Perú (ECS Fargate)",
  "main": "dist/index.js",
  "scripts": {
    "dev": "nodemon --watch src --ext ts --exec \"DOTENV_CONFIG_PATH=.env.local ts-node -r dotenv/config src/index.ts\"",
    "build": "tsc",
    "start": "DOTENV_CONFIG_PATH=.env.local node -r dotenv/config dist/index.js",
    "analyze": "DOTENV_CONFIG_PATH=.env.local ts-node -r dotenv/config local-provider-kit/analyzer.ts",
    "typecheck": "tsc --noEmit",
    "test": "node --require ts-node/register --test tests/unit/*.test.ts",
    "build:lambda": "npm --prefix lambda-ingest-lobby run build:lambda"
  },
  "keywords": [
    "lobby",
    "realtime",
    "bff",
    "websocket",
    "express",
    "redis",
    "casino"
  ],
  "author": "Atlantic City Engineering",
  "license": "ISC",
  "dependencies": {
    "@aws-sdk/client-apigatewaymanagementapi": "^3.1065.0",
    "@aws-sdk/client-dynamodb": "^3.1065.0",
    "@aws-sdk/lib-dynamodb": "^3.1065.0",
    "axios": "^1.7.2",
    "dotenv": "^16.4.5",
    "express": "^4.19.2",
    "ioredis": "^5.4.1",
    "kafkajs": "^2.2.4",
    "ws": "^8.17.0",
    "zod": "^3.23.8"
  },
  "devDependencies": {
    "@types/express": "^4.17.21",
    "@types/node": "^20.14.2",
    "@types/ws": "^8.5.10",
    "nodemon": "^3.1.3",
    "ts-node": "^10.9.2",
    "typescript": "^5.4.5"
  }
}
